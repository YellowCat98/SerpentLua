{
	"geode": "5.6.1",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "yellowcat98.serpentlua",
	"name": "SerpentLua",
	"version": "v1.3.0",
	"developer": "YellowCat98",
	"description": "Make your own mods in Lua.",
	"early-load": true,
	"tags": ["developer", "api", "universal", "offline", "utility"],
	"links": {
		"source": "https://github.com/YellowCat98/SerpentLua",
		"community": "https://discord.com/invite/qnPgmUVZsV"
	},
	"api": {
		"include": [
			"include/SerpentLua.hpp"
		]
	},
	"resources": {
		"sprites": [
			"resources/*.png"
		]
	},
	"settings": {
		"open-scripts-btn": {
			"type": "custom:open-scripts-btn",
			"name": "Open scripts buttons"
		},
		"overwrite": {
			"name": "Skip Overwrite Confirmation",
			"description": "Overwrites existing plugins/scripts when importing.",
			"type": "bool",
			"default": false,
			"requires-restart": false
		},
		"dev-mode": {
			"name": "Dev Mode",
			"description": "Allows loading plugins that aren't imported through the plugin importer.",
			"type": "bool",
			"default": false,
			"requires-restart": true
		}
	}
}
